# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file — it is in .gitignore.
# This app uses PKCE (public client OAuth) — NO client secret is needed or safe to store here.

# Cockpit CMS — get the API token from your Cockpit admin panel
EXPO_PUBLIC_COCKPIT_API_URL=https://your-cockpit-instance.com/api
EXPO_PUBLIC_COCKPIT_API_TOKEN=

# Microsoft Entra ID — find these in Azure Portal → App registrations → your app → Overview
# Use a public client (PKCE) registration. Do NOT paste a client secret here.
EXPO_PUBLIC_ENTRA_CLIENT_ID=
EXPO_PUBLIC_ENTRA_TENANT_ID=
EXPO_PUBLIC_ENTRA_REDIRECT_SCHEME=msauth.your.bundle.id

# Legacy REST API base URL (optional — only if you use the api.ts legacy login)
# EXPO_PUBLIC_API_BASE_URL=https://your-api.example.com
